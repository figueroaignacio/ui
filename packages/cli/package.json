{
  "name": "nachui",
  "version": "1.0.8",
  "type": "module",
  "description": "Official CLI for NachUI",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "nachui": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test:dev": "tsx src/index.ts",
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "release": "pnpm build && npm publish",
    "release:patch": "npm version patch && pnpm release",
    "release:minor": "npm version minor && pnpm release"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "commander": "^14.0.3",
    "kleur": "^4.1.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
