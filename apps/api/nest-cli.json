{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "webpack",
    "deleteOutDir": true,
    "assets": [{ "include": "modules/themes/css/**/*.css", "watchAssets": true }]
  },
  "exec": "node -r dotenv/config"
}
