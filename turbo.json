{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", ".velite/**", "!.next/cache/**"],
      "env": ["GOOGLE_GENERATIVE_AI_API_KEY", "POSTGRES_URL", "FRONTEND_URL"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.*"]
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": ["transit"]
    }
  }
}
