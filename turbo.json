{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["GOOGLE_GENERATIVE_AI_API_KEY", "POSTGRES_URL", "FRONTEND_URL"],
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", ".velite/**", "!.next/cache/**", "dist/**"],
      "env": ["GOOGLE_GENERATIVE_AI_API_KEY", "POSTGRES_URL", "FRONTEND_URL"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "start": {
      "persistent": true,
      "cache": false
    },
    "lint": {
      "dependsOn": ["^lint"]
    }
  }
}
